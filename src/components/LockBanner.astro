---
interface Props {
  lockDate: string;
  revised: string;
}

const { lockDate, revised } = Astro.props;

function formatDate(value?: string) {
  if (!value) return '';

  return new Date(value).toLocaleDateString('en-AU', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}
---

<div class="lock-banner">
  <span class="lock-icon">&#128274;</span>
  <span>
    <strong>Canonically locked</strong> since {formatDate(lockDate)} · Revised {formatDate(revised)}.
  </span>
</div>
