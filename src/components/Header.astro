---
const { pathname } = Astro.url;

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'What Is APS?', href: '/orientation/what-is-aps/' },
  { label: 'Foundations', href: '/clusters/foundations/' },
  { label: 'Cognition & Mind', href: '/clusters/cognition-mind/' },
  { label: 'Empirical Interface', href: '/clusters/empirical-interface/' },
  { label: 'Clusters', href: '/streams/' },
  { label: 'Glossary', href: '/glossary/' },
];
---

<nav class="site-nav">
  <div class="nav-inner">
    <a href="/" class="nav-brand">APS<span>Publishing Platform</span></a>
    <button class="nav-toggle" id="nav-toggle" aria-label="Toggle navigation">&#9776;</button>
    <ul class="nav-links" id="nav-links">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              aria-current={
                pathname === item.href || pathname.startsWith(item.href + '/') ? 'page' : undefined
              }
            >
              {item.label}
            </a>
          </li>
        ))
      }
      <li>
        <a href="/search/" class="nav-search-btn">&#128269; Search</a>
      </li>
    </ul>
  </div>
</nav>

<script>
  document.getElementById('nav-toggle')?.addEventListener('click', () => {
    document.getElementById('nav-links')?.classList.toggle('open');
  });
</script>
