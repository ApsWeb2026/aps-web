---
const { pathname } = Astro.url;

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'What Is APS', href: '/orientation/what-is-aps/' },
  { label: 'Articles', href: '/articles/' },
  { label: 'Glossary', href: '/glossary/' },
];

const clusterItems = [
  { label: 'Foundations of Life', href: '/clusters/foundations/' },
  { label: 'Definition & Borderlines', href: '/clusters/definition-borderlines/' },
  { label: 'Cognition & Mind', href: '/clusters/cognition-mind/' },
  { label: 'Empirical Interface', href: '/clusters/empirical-interface/' },
  { label: 'Scale, Time, and Organisation', href: '/clusters/scaling-complexity/' },
  { label: 'Historical & Philosophical Context', href: '/clusters/historical-context/' },
  { label: 'Conceptual Foundations & Explanatory Grammar', href: '/clusters/conceptual-foundations/' },
];
---

<nav class="site-nav">
  <div class="nav-inner">
    <a href="/" class="nav-brand">APS<span>Publishing Platform</span></a>

    <button class="nav-toggle" id="nav-toggle" aria-label="Toggle navigation">&#9776;</button>

    <ul class="nav-links" id="nav-links">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              aria-current={
                pathname === item.href || pathname.startsWith(item.href + '/') ? 'page' : undefined
              }
            >
              {item.label}
            </a>
          </li>
        ))
      }

      <li class="nav-dropdown">
        <button class="nav-dropdown-toggle" aria-expanded="false" aria-haspopup="true">
          Clusters <span class="dropdown-arrow">&#9662;</span>
        </button>

        <ul class="nav-dropdown-menu">
          {
            clusterItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  aria-current={pathname === item.href ? 'page' : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </li>

      <li>
        <a href="/search/" class="nav-search-btn">&#128269; Search</a>
      </li>
    </ul>
  </div>
</nav>

<script>
  document.getElementById('nav-toggle')?.addEventListener('click', () => {
    document.getElementById('nav-links')?.classList.toggle('open');
  });

  document.querySelectorAll('.nav-dropdown-toggle').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const parent = (e.currentTarget as HTMLElement).parentElement;
      parent?.classList.toggle('open');
      btn.setAttribute('aria-expanded', parent?.classList.contains('open') ? 'true' : 'false');
    });
  });

  document.addEventListener('click', () => {
    document.querySelectorAll('.nav-dropdown.open').forEach((el) => {
      el.classList.remove('open');
      el.querySelector('.nav-dropdown-toggle')?.setAttribute('aria-expanded', 'false');
    });
  });
</script>