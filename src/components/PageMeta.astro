---
import StatusBadge from './StatusBadge.astro';
import TypeBadge from './TypeBadge.astro';

interface Props {
  status: 'draft' | 'evolving' | 'canonical';
  type: 'article' | 'glossary' | 'stream' | 'orientation' | 'diagram' | 'box';
  cluster?: string;
  date?: string;
  revised?: string;
}

const { status, type, cluster, date, revised } = Astro.props;

const clusterLabels: Record<string, string> = {
  foundations: 'Foundations of Life',
  'definition-borderlines': 'Definition & Borderlines',
  'cognition-mind': 'Cognition & Mind',
  'empirical-interface': 'Empirical Interface',
  'scaling-complexity': 'Scale, Time, and Organisation',
  'historical-context': 'Historical & Philosophical Context',
  'conceptual-foundations': 'Conceptual Foundations & Explanatory Grammar',
};
---

<div class="page-meta">
  <StatusBadge status={status} />
  <TypeBadge type={type} />
  {
    cluster && (
      <>
        <span class="page-meta-divider">|</span>
        <span class="page-meta-item">
          <a href={`/clusters/${cluster}/`}>{clusterLabels[cluster] || cluster}</a>
        </span>
      </>
    )
  }
  {
    date && (
      <>
        <span class="page-meta-divider">|</span>
        <span class="page-meta-item">Created: {date}</span>
      </>
    )
  }
  {
    revised && (
      <>
        <span class="page-meta-divider">|</span>
        <span class="page-meta-item">Revised: {revised}</span>
      </>
    )
  }
</div>