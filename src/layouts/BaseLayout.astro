---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A structured research instrument for the Agency-Process-Scale framework.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <title>{title} — APS Publishing Platform</title>
  <link rel="sitemap" href="/sitemap-index.xml">
</head>
<body>
  <Header />
  <main class="page-wrapper">
    <slot />
  </main>
  <Footer />
</body>
</html>
