---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import PageMeta from '@/components/PageMeta.astro';
import LockBanner from '@/components/LockBanner.astro';
import References from '@/components/References.astro';

export async function getStaticPaths() {
  const entries = await getCollection('glossary');
  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const {
  title,
  slug,
  definition,
  inBrief,
  status,
  canonical,
  canonicalLockDate,
  date,
  revised,
  cluster,
  seeAlso,
  references,
} = entry.data;

// Build backlinks
const articles = await getCollection('articles');
const allStreams = await getCollection('streams');
const orientationPages = await getCollection('orientation');

const backlinks: { title: string; href: string; status: string; type: string }[] = [];

for (const article of articles) {
  if (
    article.data.relatedGlossaryTerms?.includes(slug) ||
    (article.body && article.body.includes(`/glossary/${slug}/`))
  ) {
    backlinks.push({
      title: article.data.title,
      href: `/articles/${article.data.slug}/`,
      status: article.data.status,
      type: 'article',
    });
  }
}

for (const page of orientationPages) {
  if (
    page.data.relatedGlossaryTerms?.includes(slug) ||
    (page.body && page.body.includes(`/glossary/${slug}/`))
  ) {
    backlinks.push({
      title: page.data.title,
      href: `/orientation/${page.data.slug}/`,
      status: page.data.status,
      type: 'orientation',
    });
  }
}

for (const stream of allStreams) {
  if (
    stream.data.associatedGlossaryTerms?.includes(slug) ||
    (stream.body && stream.body.includes(`/glossary/${slug}/`))
  ) {
    backlinks.push({
      title: stream.data.title,
      href: `/streams/${stream.data.slug}/`,
      status: stream.data.status,
      type: 'stream',
    });
  }
}

// Deduplicate backlinks by href
const uniqueBacklinks = Array.from(
  new Map(backlinks.map((backlink) => [backlink.href, backlink])).values(),
);

// Promote core APS references, then sort by status, type, and title
const corePriority = [
  'what-is-aps',
  'understanding-aps-the-structure-of-the-framework',
  'explanatory-geometry-of-biology',
];

const statusOrder: Record<string, number> = { canonical: 0, evolving: 1, draft: 2 };
const typeOrder: Record<string, number> = { orientation: 0, article: 1, stream: 2 };

function getSlugFromHref(href: string) {
  return href.split('/').filter(Boolean).pop() ?? '';
}

uniqueBacklinks.sort((a, b) => {
  const aCoreIndex = corePriority.indexOf(getSlugFromHref(a.href));
  const bCoreIndex = corePriority.indexOf(getSlugFromHref(b.href));

  if (aCoreIndex !== -1 || bCoreIndex !== -1) {
    if (aCoreIndex === -1) return 1;
    if (bCoreIndex === -1) return -1;
    return aCoreIndex - bCoreIndex;
  }

  return (
    (statusOrder[a.status] ?? 9) - (statusOrder[b.status] ?? 9) ||
    (typeOrder[a.type] ?? 9) - (typeOrder[b.type] ?? 9) ||
    a.title.localeCompare(b.title)
  );
});

// Progressive disclosure
const visibleBacklinks = uniqueBacklinks.slice(0, 5);
const hiddenBacklinks = uniqueBacklinks.slice(5);

// See also
const glossaryEntries = await getCollection('glossary');
const seeAlsoEntries = seeAlso
  .map((s: string) => glossaryEntries.find((g) => g.data.slug === s))
  .filter(Boolean);
---

<BaseLayout title={title} description={inBrief}>
  <div
    class="content-wrapper"
    data-pagefind-body
    data-pagefind-weight="10"
    data-pagefind-meta={`type:Glossary, status:${status.charAt(0).toUpperCase() + status.slice(1)}, cluster:${cluster}`}
  >
    <span data-pagefind-filter="type:Glossary" data-pagefind-ignore></span>
    <span
      data-pagefind-filter={`status:${status.charAt(0).toUpperCase() + status.slice(1)}`}
      data-pagefind-ignore
    ></span>

    <Breadcrumb items={[{ label: 'Glossary', href: '/glossary/' }, { label: title }]} />

    <header class="page-header">
      <h1 data-pagefind-weight="50">{title}</h1>
      <PageMeta status={status} type="glossary" cluster={cluster} date={date} revised={revised} />
    </header>

    {
      canonical && canonicalLockDate && (
        <LockBanner lockDate={canonicalLockDate} revised={revised} />
      )
    }

    <div class="definition-block" data-pagefind-weight="30">
      <div class="definition-label">Definition</div>
      <div class="definition-text">{definition}</div>
    </div>

    <div class="in-brief">
      <div class="in-brief-label">In Brief</div>
      <p>{inBrief}</p>
    </div>

    <div class="article-body">
      <Content />
    </div>

    {
      seeAlsoEntries.length > 0 && (
        <div class="see-also">
          <h3>See Also</h3>
          <ul class="tag-list">
            {seeAlsoEntries.map((g: any) => (
              <li>
                <a href={`/glossary/${g.data.slug}/`}>{g.data.title}</a>
              </li>
            ))}
          </ul>
        </div>
      )
    }

    {
      uniqueBacklinks.length > 0 && (
        <section class="referenced-by">
          <h2>Referenced By</h2>

          <ul class="backlink-list">
            {visibleBacklinks.map((bl) => (
              <li class="backlink-item">
                <a href={bl.href}>{bl.title}</a>
                <span class={`badge badge-type badge-${bl.type}`}>
                  {bl.type.charAt(0).toUpperCase() + bl.type.slice(1)}
                </span>
                <span class={`badge badge-${bl.status}`}>
                  {bl.status.charAt(0).toUpperCase() + bl.status.slice(1)}
                </span>
              </li>
            ))}
          </ul>

          {
            hiddenBacklinks.length > 0 && (
              <details class="backlink-more">
                <summary>Show all references ({uniqueBacklinks.length})</summary>

                <ul class="backlink-list">
                  {hiddenBacklinks.map((bl) => (
                    <li class="backlink-item">
                      <a href={bl.href}>{bl.title}</a>
                      <span class={`badge badge-type badge-${bl.type}`}>
                        {bl.type.charAt(0).toUpperCase() + bl.type.slice(1)}
                      </span>
                      <span class={`badge badge-${bl.status}`}>
                        {bl.status.charAt(0).toUpperCase() + bl.status.slice(1)}
                      </span>
                    </li>
                  ))}
                </ul>
              </details>
            )
          }
        </section>
      )
    }

    <References references={references} />
  </div>
</BaseLayout>