---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';

// Fetch canonical publications for optional section
const allArticles = await getCollection('articles');
const allGlossary = await getCollection('glossary');
const canonicalItems = [
  ...allArticles.filter((a) => a.data.status === 'canonical'),
  ...allGlossary.filter((g) => g.data.status === 'canonical'),
].sort((a, b) => b.data.revised.localeCompare(a.data.revised)).slice(0, 3);
---

<BaseLayout
  title="Home"
  description="Agency, Process, Scale — a structured knowledge system for the APS Framework."
>
  <div class="content-wrapper">
    <!-- Hero -->
    <section class="hero">
      <h1>Agency &middot; Process &middot; Scale</h1>
      <p class="subtitle">
        A structured knowledge system for the APS Framework &mdash; integrating canonical definitions,
        conceptual articles, and research streams into a unified account of life as
        viability-oriented, constraint-closed organisation.
      </p>
      <div class="hero-links">
        <a href="/orientation/what-is-aps/" class="btn btn-primary">
          What Is APS? &mdash; A One-Page Overview
        </a>
      </div>
      <p class="hero-guidance">
        If you are new to APS, begin here, then continue to
        <a href="/orientation/understanding-aps-the-structure-of-the-framework/">
          Understanding APS &mdash; The Structure of the Framework
        </a>.
      </p>
      <p class="hero-explore">
        Explore the framework through:
        <a href="/glossary/">Glossary</a> (core definitions),
        <a href="/articles/">Articles</a> (organised by conceptual clusters)
      </p>
    </section>

    <!-- Start Here -->
    <section class="home-section">
      <h2>Start Here</h2>
      <ul class="card-list">
        <li class="card">
          <div class="card-header">
            <h3 class="card-title">
              <a href="/orientation/what-is-aps/">What Is APS?</a>
            </h3>
            <span class="badge badge-type badge-orientation">Orientation</span>
          </div>
          <p class="card-excerpt">
            A concise overview of the Agency&ndash;Process&ndash;Scale framework.
          </p>
        </li>
        <li class="card">
          <div class="card-header">
            <h3 class="card-title">
              <a href="/orientation/understanding-aps-the-structure-of-the-framework/">
                Understanding APS &mdash; The Structure of the Framework
              </a>
            </h3>
            <span class="badge badge-type badge-orientation">Orientation</span>
          </div>
          <p class="card-excerpt">
            A guided introduction to how the framework fits together.
          </p>
        </li>
        <li class="card">
          <div class="card-header">
            <h3 class="card-title">
              <a href="/orientation/the-aps-glossary-why-definitions-matter/">
                APS Glossary &mdash; Why Definitions Matter
              </a>
            </h3>
            <span class="badge badge-type badge-orientation">Orientation</span>
          </div>
          <p class="card-excerpt">
            How key APS concepts are defined and used across the framework.
          </p>
        </li>
      </ul>
      <p>
        If you are unsure where to begin, start with <strong>What Is APS?</strong>, then continue to
        <strong> Understanding APS</strong>.
      </p>
    </section>

    <!-- Beyond Common Explanations -->
    <section class="home-section">
      <h2>Understanding Life &mdash; Beyond Common Explanations</h2>
      <p>
        Many modern theories explain important aspects of life&mdash;genes, information, control,
        inference, and self-organisation.
      </p>
      <p>
        But none of these alone explains what makes a system alive.
      </p>
      <p>
        The APS framework clarifies this by showing that life is not defined by any single mechanism
        or process, but by the organisation that sustains itself through ongoing activity.
      </p>

      <ul class="card-list">
        <li class="card">
          <div class="card-header">
            <h3 class="card-title">
              <a href="/articles/why-life-is-not-dnas-way-of-making-more-dna/">
                Why Life Is Not DNA&rsquo;s Way of Making More DNA
              </a>
            </h3>
            <span class="badge badge-type badge-article">Article</span>
          </div>
          <p class="card-excerpt">
            Why genes matter profoundly in biology without defining what life is.
          </p>
        </li>

        <li class="card">
          <div class="card-header">
            <h3 class="card-title">
              <a href="/articles/why-life-is-not-a-machine/">
                Why Life Is Not a Machine
              </a>
            </h3>
            <span class="badge badge-type badge-article">Article</span>
          </div>
          <p class="card-excerpt">
            Why mechanistic description captures important processes without exhausting living organisation.
          </p>
        </li>

        <li class="card">
          <div class="card-header">
            <h3 class="card-title">
              <a href="/articles/why-life-is-not-information-processing/">
                Why Life Is Not Information Processing
              </a>
            </h3>
            <span class="badge badge-type badge-article">Article</span>
          </div>
          <p class="card-excerpt">
            Why information becomes meaningful only within viability-oriented organisation.
          </p>
        </li>

        <li class="card">
          <div class="card-header">
            <h3 class="card-title">
              <a href="/articles/why-life-is-not-active-inference/">
                Why Life Is Not Active Inference
              </a>
            </h3>
            <span class="badge badge-type badge-article">Article</span>
          </div>
          <p class="card-excerpt">
            Why prediction and inference describe modes of activity within life rather than life itself.
          </p>
        </li>
      </ul>

      <p>
        These articles form part of a broader comparative series situating APS in relation to major
        contemporary frameworks in biology and cognition.
      </p>
      <a href="/articles/aps-and-contemporary-theories/" class="btn btn-secondary">
        Explore All Comparisons
      </a>
    </section>

    <!-- Understand the Framework -->
    <section class="home-section">
      <h2>Understand the Framework</h2>
      <ul class="card-list">
        <li class="card">
          <div class="card-header">
            <h3 class="card-title">
              <a href="/orientation/understanding-aps-the-structure-of-the-framework/">
                Understanding APS &mdash; The Structure of the Framework
              </a>
            </h3>
            <span class="badge badge-type badge-orientation">Orientation</span>
          </div>
          <p class="card-excerpt">
            How the APS framework is organised, how its components relate, and how to navigate the conceptual structure.
          </p>
        </li>
        <li class="card">
          <div class="card-header">
            <h3 class="card-title">
              <a href="/orientation/the-core-structure-of-aps-how-the-framework-fits-together/">
                The Core Structure of APS &mdash; How the Framework Fits Together
              </a>
            </h3>
            <span class="badge badge-type badge-orientation">Orientation</span>
          </div>
          <p class="card-excerpt">
            A more formal account of the framework&rsquo;s conceptual architecture.
          </p>
        </li>
      </ul>
    </section>

    <!-- Glossary -->
    <section class="home-section">
      <h2>APS Glossary &mdash; Why Definitions Matter</h2>
      <p>
        The glossary is the conceptual spine of the APS framework. Each entry provides a precise,
        governed definition grounded in the framework&rsquo;s commitments to agency, process, and
        scale.
      </p>
      <a href="/glossary/" class="btn btn-secondary">Browse the Glossary</a>
    </section>

    <!-- Recent Canonical Publications (optional) -->
    {
      canonicalItems.length > 0 && (
        <section class="home-section">
          <h2>Recent Canonical Publications</h2>
          <ul class="card-list">
            {canonicalItems.map((item) => {
              const isArticle = 'abstract' in item.data;
              const type = isArticle ? 'article' : 'glossary';
              const href = isArticle
                ? `/articles/${item.data.slug}/`
                : `/glossary/${item.data.slug}/`;
              const excerpt = isArticle
                ? (item.data as any).abstract
                : (item.data as any).inBrief;
              return (
                <li class="card">
                  <div class="card-header">
                    <h3 class="card-title">
                      <a href={href}>{item.data.title}</a>
                    </h3>
                    <span class="badge badge-canonical">Canonical</span>
                    <span class={`badge badge-type badge-${type}`}>
                      {type.charAt(0).toUpperCase() + type.slice(1)}
                    </span>
                  </div>
                  <p class="card-excerpt">{excerpt}</p>
                  <div class="card-meta">Revised: {item.data.revised}</div>
                </li>
              );
            })}
          </ul>
        </section>
      )
    }
  </div>
</BaseLayout>