---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';

// Fetch canonical publications for optional section
const allArticles = await getCollection('articles');
const allGlossary = await getCollection('glossary');

const canonicalItems = [
  ...allArticles.filter((a) => a.data.status === 'canonical'),
  ...allGlossary.filter((g) => g.data.status === 'canonical'),
]
  .sort((a, b) => new Date(b.data.revised).getTime() - new Date(a.data.revised).getTime())
  .slice(0, 3);
---

function formatDate(value?: string) {
  if (!value) return '';

  return new Date(value).toLocaleDateString('en-AU', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}

<BaseLayout
  title="Home"
  description="Agency, Process, Scale — a structured framework for understanding life as viability-oriented, constraint-closed organisation."
>
  <div class="content-wrapper">
    <section class="hero">
      <h1>Agency &middot; Process &middot; Scale</h1>

      <p class="subtitle">
        A structured framework for understanding life as viability-oriented, constraint-closed
        organisation.
      </p>

      <p class="hero-guidance">
        APS brings together concepts from across biology into a unified explanatory system, showing
        how living systems sustain, regulate, and transform themselves across space and time. Rather
        than focusing on isolated components or fixed levels, it clarifies the organisation through
        which life persists and evolves.
      </p>

      <div class="hero-links">
        <a href="/orientation/aps-viability-oriented-framework/" class="btn btn-primary">
          APS &mdash; A Viability-Oriented Framework for Understanding Life
        </a>
      </div>

      <p class="hero-guidance">
        If you are new to APS, begin with
        <a href="/orientation/aps-viability-oriented-framework/">
          APS &mdash; A Viability-Oriented Framework for Understanding Life
        </a>.
      </p>

      <p class="hero-guidance">
        For the clearest entry into the conceptual core of the framework, follow
        <a href="/orientation/how-aps-explains-life/">
          How APS Explains Life &mdash; A Two-Step Guide
        </a>.
      </p>

      <p class="hero-explore">
        Explore the framework through:
        <a href="/glossary/">Glossary</a> (core definitions),
        <a href="/articles/">Articles</a> (organised by conceptual clusters)
      </p>
    </section>

    <section class="home-section">
      <h2>Start Here</h2>
      <ul class="card-list">
        <li class="card">
          <div class="card-header">
            <h3 class="card-title">
              <a href="/orientation/aps-viability-oriented-framework/">
                APS &mdash; A Viability-Oriented Framework for Understanding Life
              </a>
            </h3>
            <span class="badge badge-type badge-orientation">Orientation</span>
          </div>
          <p class="card-excerpt">
            A canonical introduction to APS as a framework for understanding life as
            viability-oriented, constraint-closed organisation.
          </p>
        </li>

        <li class="card">
          <div class="card-header">
            <h3 class="card-title">
              <a href="/articles/biological-explanation-what-needs-to-be-explained/">
                Biological Explanation &mdash; What Needs to Be Explained
              </a>
            </h3>
            <span class="badge badge-type badge-article">Article</span>
          </div>
          <p class="card-excerpt">
            A first step into APS: what biological explanation must explain if living systems are to
            be understood as living.
          </p>
        </li>

        <li class="card">
          <div class="card-header">
            <h3 class="card-title">
              <a href="/articles/structure-of-biological-explanation-in-aps/">
                The Structure of Biological Explanation in APS
              </a>
            </h3>
            <span class="badge badge-type badge-article">Article</span>
          </div>
          <p class="card-excerpt">
            A systematic account of how APS organises explanation through agency, process, scale,
            temporal dynamics, and coupling.
          </p>
        </li>

        <li class="card">
          <div class="card-header">
            <h3 class="card-title">
              <a href="/articles/physiology-and-evolution-in-aps-two-temporal-perspectives-on-the-same-biological-organisation/">
                Physiology and Evolution in APS
              </a>
            </h3>
            <span class="badge badge-type badge-article">Article</span>
          </div>
          <p class="card-excerpt">
            A clear application of APS showing how present-time regulation and historical
            transformation belong to one explanatory system.
          </p>
        </li>
      </ul>
    </section>

    <section class="home-section">
      <h2>Comparing Frameworks</h2>

      <p>
        These articles show how major theories capture important aspects of life while failing to
        explain viability-oriented organisation.
      </p>

      <ul class="card-list">
        <li class="card">
          <div class="card-header">
            <h3 class="card-title">
              <a href="/articles/why-life-is-not-dnas-way-of-making-more-dna/">
                Why Life Is Not DNA&rsquo;s Way of Making More DNA
              </a>
            </h3>
            <span class="badge badge-type badge-article">Article</span>
          </div>
          <p class="card-excerpt">
            Why genes matter profoundly in biology without defining what life is.
          </p>
        </li>

        <li class="card">
          <div class="card-header">
            <h3 class="card-title">
              <a href="/articles/why-life-is-not-a-machine/">
                Why Life Is Not a Machine
              </a>
            </h3>
            <span class="badge badge-type badge-article">Article</span>
          </div>
          <p class="card-excerpt">
            Why mechanistic description captures important processes without exhausting living
            organisation.
          </p>
        </li>

        <li class="card">
          <div class="card-header">
            <h3 class="card-title">
              <a href="/articles/why-life-is-not-information-processing/">
                Why Life Is Not Information Processing
              </a>
            </h3>
            <span class="badge badge-type badge-article">Article</span>
          </div>
          <p class="card-excerpt">
            Why information becomes meaningful only within viability-oriented organisation.
          </p>
        </li>

        <li class="card">
          <div class="card-header">
            <h3 class="card-title">
              <a href="/articles/why-life-is-not-control-theory/">
                Why Life Is Not Control Theory
              </a>
            </h3>
            <span class="badge badge-type badge-article">Article</span>
          </div>
          <p class="card-excerpt">
            Why regulation alone does not explain why biological organisation matters.
          </p>
        </li>

        <li class="card">
          <div class="card-header">
            <h3 class="card-title">
              <a href="/articles/why-life-is-not-active-inference/">
                Why Life Is Not Active Inference
              </a>
            </h3>
            <span class="badge badge-type badge-article">Article</span>
          </div>
          <p class="card-excerpt">
            Why prediction and inference describe modes of activity within life rather than life
            itself.
          </p>
        </li>

        <li class="card">
          <div class="card-header">
            <h3 class="card-title">
              <a href="/articles/why-life-is-not-enactivism/">
                Why Life Is Not Enactivism
              </a>
            </h3>
            <span class="badge badge-type badge-article">Article</span>
          </div>
          <p class="card-excerpt">
            Why sense-making describes cognition without explaining the organisation that makes it
            possible.
          </p>
        </li>

        <li class="card">
          <div class="card-header">
            <h3 class="card-title">
              <a href="/articles/why-life-is-not-autopoiesis/">
                Why Life Is Not Autopoiesis
              </a>
            </h3>
            <span class="badge badge-type badge-article">Article</span>
          </div>
          <p class="card-excerpt">
            Why self-production captures organisation without fully explaining biological
            normativity.
          </p>
        </li>
      </ul>

      <a href="/articles/aps-and-contemporary-theories/" class="btn btn-secondary">
        Explore All Comparisons
      </a>
    </section>

    <section class="home-section">
      <h2>Integrating Theories</h2>

      <p>
        These articles show how APS incorporates and extends existing approaches within a unified
        account of viability-oriented organisation.
      </p>

      <ul class="card-list">
        <li class="card">
          <div class="card-header">
            <h3 class="card-title">
              <a href="/articles/aps-and-systems-theory/">
                APS and Systems Theory &mdash; Similarities, Differences, and Limits
              </a>
            </h3>
            <span class="badge badge-type badge-article">Article</span>
          </div>
          <p class="card-excerpt">
            How APS situates systems theory within a broader account of biological organisation.
          </p>
        </li>

        <li class="card">
          <div class="card-header">
            <h3 class="card-title">
              <a href="/articles/aps-and-autonomy-theory/">
                APS and Autonomy Theory &mdash; From Constraint Closure to Viability-Oriented
                Organisation
              </a>
            </h3>
            <span class="badge badge-type badge-article">Article</span>
          </div>
          <p class="card-excerpt">
            How APS extends autonomy theory into a unified account across scale and evolution.
          </p>
        </li>

        <li class="card">
          <div class="card-header">
            <h3 class="card-title">
              <a href="/articles/aps-and-the-extended-evolutionary-synthesis/">
                APS and the Extended Evolutionary Synthesis
              </a>
            </h3>
            <span class="badge badge-type badge-article">Article</span>
          </div>
          <p class="card-excerpt">
            How APS grounds evolutionary processes in the conditions that make them possible.
          </p>
        </li>
      </ul>
    </section>

    <section class="home-section">
      <h2>APS Glossary &mdash; Why Definitions Matter</h2>
      <p>
        The glossary is the conceptual spine of the APS framework. Each entry provides a precise,
        governed definition grounded in the framework&rsquo;s commitments to agency, process, and
        scale.
      </p>
      <a href="/glossary/" class="btn btn-secondary">Browse the Glossary</a>
    </section>

    {canonicalItems.length > 0 && (
      <section class="home-section">
        <h2>Recent Canonical Publications</h2>
        <ul class="card-list">
          {canonicalItems.map((entry) => {
            const isArticle = entry.collection === 'articles';
            const href = isArticle
              ? `/articles/${entry.data.slug}/`
              : `/glossary/${entry.data.slug}/`;

            const excerpt =
              isArticle && 'abstract' in entry.data && entry.data.abstract
                ? entry.data.abstract
                : 'inBrief' in entry.data && entry.data.inBrief
                  ? entry.data.inBrief
                  : 'definition' in entry.data && entry.data.definition
                    ? entry.data.definition
                    : null;

            return (
              <li class="card">
                <div class="card-header">
                  <h3 class="card-title">
                    <a href={href}>{entry.data.title}</a>
                  </h3>
                  <span class="badge badge-status badge-canonical">Canonical</span>
                  <span class={`badge badge-type ${isArticle ? 'badge-article' : 'badge-glossary'}`}>
                    {isArticle ? 'Article' : 'Glossary'}
                  </span>
                </div>

                {excerpt && <p class="card-excerpt">{excerpt}</p>}

                <div class="card-meta">Revised: {formatDate(entry.data.revised)}</div>
              </li>
            );
          })}
        </ul>
      </section>
    )}
  </div>
</BaseLayout>