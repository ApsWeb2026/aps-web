---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import PageMeta from '@/components/PageMeta.astro';

export async function getStaticPaths() {
  const entries = await getCollection('diagrams');
  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, svgFile, caption, description, status, revised, figureNumber } = entry.data;
---

<BaseLayout title={title} description={description}>
  <div class="content-wrapper" data-pagefind-body data-pagefind-meta={`type:Diagram, status:${status.charAt(0).toUpperCase() + status.slice(1)}`}>
    <span data-pagefind-filter="type:Diagram" data-pagefind-ignore></span>
    <span data-pagefind-filter={`status:${status.charAt(0).toUpperCase() + status.slice(1)}`} data-pagefind-ignore></span>
    <Breadcrumb items={[{ label: 'Diagrams', href: '/diagrams/' }, { label: title }]} />

    <header class="page-header">
      <h1 data-pagefind-weight="20">{title}</h1>
      <PageMeta status={status} type="diagram" revised={revised} />
    </header>

    <figure class="figure">
      <img src={svgFile} alt={description} />
      <figcaption>
        {figureNumber && <strong>Figure {figureNumber}.</strong>}
        {caption}
      </figcaption>
    </figure>

    <div class="article-body">
      <Content />
    </div>
  </div>
</BaseLayout>
