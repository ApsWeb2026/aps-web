---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import PageMeta from '@/components/PageMeta.astro';
import LockBanner from '@/components/LockBanner.astro';
import References from '@/components/References.astro';

export async function getStaticPaths() {
  const entries = await getCollection('articles');
  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const {
  title,
  abstract,
  status,
  canonical,
  canonicalLockDate,
  revised,
  cluster,
  keyPoints,
  relatedGlossaryTerms,
  relatedArticles,
  references,
} = entry.data;

// Normalize display names like "Biological Agency" to slugs like "biological-agency"
function toSlug(term: string): string {
  return term.toLowerCase().replace(/\s+/g, '-');
}

const allArticles = await getCollection('articles');
const allGlossary = await getCollection('glossary');
const allOrientation = await getCollection('orientation');

const resolvedRelatedArticles = (relatedArticles ?? [])
  .map((slug: string) => {
    const article = allArticles.find((a) => a.data.slug === slug);
    if (article) return { slug: article.data.slug, title: article.data.title, href: `/articles/${article.data.slug}/` };
    const orient = allOrientation.find((o) => o.data.slug === slug);
    if (orient) return { slug: orient.data.slug, title: orient.data.title, href: `/orientation/${orient.data.slug}/` };
    return null;
  })
  .filter(Boolean) as { slug: string; title: string; href: string }[];

const resolvedGlossaryTerms = (relatedGlossaryTerms ?? [])
  .map((term: string) => {
    const normalized = toSlug(term);
    const found = allGlossary.find((g) => g.data.slug === normalized);
    return found ? { slug: found.data.slug, title: found.data.title } : null;
  })
  .filter(Boolean) as { slug: string; title: string }[];
---

<BaseLayout title={title} description={abstract}>
  <div class="content-wrapper" data-pagefind-body data-pagefind-meta={`type:Article, status:${status.charAt(0).toUpperCase() + status.slice(1)}, cluster:${cluster}`}>
    <span data-pagefind-filter="type:Article" data-pagefind-ignore></span>
    <span data-pagefind-filter={`status:${status.charAt(0).toUpperCase() + status.slice(1)}`} data-pagefind-ignore></span>
    <Breadcrumb items={[{ label: 'Articles', href: '/articles/' }, { label: title }]} />

    <header class="page-header">
      <h1 data-pagefind-weight="20">{title}</h1>
      <PageMeta status={status} type="article" cluster={cluster} revised={revised} />
    </header>

    {
      canonical && canonicalLockDate && (
        <LockBanner lockDate={canonicalLockDate} revised={revised} />
      )
    }

    <div class="abstract">
      <div class="abstract-label">Abstract</div>
      <p>{abstract}</p>
    </div>

    {
      keyPoints.length > 0 && (
        <div class="key-points">
          <h3>Key Points</h3>
          <ul>
            {keyPoints.map((point: string) => (
              <li>{point}</li>
            ))}
          </ul>
        </div>
      )
    }

    <div class="article-body">
      <Content />
    </div>

    {resolvedGlossaryTerms.length > 0 && (
      <div class="see-also">
        <h3>See Also</h3>
        <ul class="tag-list">
          {resolvedGlossaryTerms.map((term) => (
            <li><a href={`/glossary/${term.slug}/`}>{term.title}</a></li>
          ))}
        </ul>
      </div>
    )}

    {resolvedRelatedArticles.length > 0 && (
      <div class="see-also">
        <h3>Related Articles</h3>
        <ul class="tag-list">
          {resolvedRelatedArticles.map((item) => (
            <li><a href={item.href}>{item.title}</a></li>
          ))}
        </ul>
      </div>
    )}

    <References references={references} />
  </div>
</BaseLayout>
