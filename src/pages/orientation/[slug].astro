---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import PageMeta from '@/components/PageMeta.astro';
import LockBanner from '@/components/LockBanner.astro';

export async function getStaticPaths() {
  const entries = await getCollection('orientation');
  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, status, canonical, canonicalLockDate, revised, relatedGlossaryTerms, relatedArticles } = entry.data;

const allArticles = await getCollection('articles');
const resolvedRelatedArticles = (relatedArticles ?? [])
  .map((slug: string) => {
    const found = allArticles.find((a) => a.data.slug === slug);
    return found ? { slug: found.data.slug, title: found.data.title } : null;
  })
  .filter(Boolean) as { slug: string; title: string }[];
---

<BaseLayout title={title} description={`${title} — APS Orientation`}>
  <div class="content-wrapper" data-pagefind-body data-pagefind-meta={`type:Orientation, status:${status.charAt(0).toUpperCase() + status.slice(1)}`}>
    <span data-pagefind-filter="type:Orientation" data-pagefind-ignore></span>
    <span data-pagefind-filter={`status:${status.charAt(0).toUpperCase() + status.slice(1)}`} data-pagefind-ignore></span>
    <Breadcrumb
      items={[{ label: 'Orientation', href: '/orientation/what-is-aps/' }, { label: title }]}
    />

    <header class="page-header">
      <h1 data-pagefind-weight="20">{title}</h1>
      <PageMeta status={status} type="orientation" revised={revised} />
    </header>

    {
      canonical && canonicalLockDate && (
        <LockBanner lockDate={canonicalLockDate} revised={revised} />
      )
    }

    <div class="article-body">
      <Content />
    </div>

    {relatedGlossaryTerms && relatedGlossaryTerms.length > 0 && (
      <div class="see-also">
        <h3>See Also</h3>
        <ul class="tag-list">
          {relatedGlossaryTerms.map((term: string) => (
            <li><a href={`/glossary/${term}/`}>{term.replace(/-/g, ' ')}</a></li>
          ))}
        </ul>
      </div>
    )}

    {resolvedRelatedArticles.length > 0 && (
      <div class="see-also">
        <h3>Related Articles</h3>
        <ul class="tag-list">
          {resolvedRelatedArticles.map((article) => (
            <li><a href={`/articles/${article.slug}/`}>{article.title}</a></li>
          ))}
        </ul>
      </div>
    )}
  </div>
</BaseLayout>
